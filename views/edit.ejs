<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-900 p-10 text-white">
        
            <h1 class="text-3xl tracking-tighter mb-3">Update User</h1>
        <form action="/edit/<%= useers._id %>" method="post">
            <input  class="px-5 py-2 outline-none bg-transparent border-2 border-zinc-700 rounded-lg" type="text" name="name" placeholder="name" value="<%= useers.name %>"/>
            <input  class="px-5 py-2 outline-none bg-transparent border-2 border-zinc-700 rounded-lg" type="text" name="email" placeholder="Email" value="<%= useers.email %>"/>
            <input  class="px-5 py-2 outline-none bg-transparent border-2 border-zinc-700 rounded-lg" type="text" name="image" placeholder="Image Url" value="<%= useers.image %>"/>
            <input  class="px-5 py-2 bg-yellow-600 rounded-lg ml-3" type="submit" value="Update User"/>

        </form>
    </div>
</body>
</html>